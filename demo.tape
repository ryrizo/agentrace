Output demo.gif
Set Shell "zsh"
Set FontSize 13
Set Width 920
Set Height 850
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 60ms
Set PlaybackSpeed 0.8
Env PATH "/Users/ryanperrizo/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

Sleep 1s

# ── agentrace sessions ───────────────────────────────────────
Type "agentrace sessions"
Enter
Sleep 3.5s

# ── agentrace stats ──────────────────────────────────────────
Ctrl+L
Sleep 200ms
Type "agentrace stats"
Enter
Sleep 5s

# ── agentrace compare ────────────────────────────────────────
Ctrl+L
Sleep 200ms
Type "agentrace compare 1 6"
Enter
Sleep 4s

# ── agentrace water ──────────────────────────────────────────
Ctrl+L
Sleep 200ms
Type "agentrace water"
Enter
Sleep 4.5s

# ── agentrace recommend ──────────────────────────────────────
Ctrl+L
Sleep 200ms
Type "agentrace recommend"
Enter
Sleep 5s

Sleep 2s
