Output demo.gif
Set Shell "zsh"
Set FontSize 13
Set Width 920
Set Height 600
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 60ms
Set PlaybackSpeed 0.8
Env PATH "/Users/ryanperrizo/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

Sleep 1s

Type "agentrace sessions"
Sleep 300ms
Enter
Sleep 3s

Sleep 500ms
Type "agentrace stats"
Sleep 300ms
Enter
Sleep 4s

Sleep 500ms
Type "agentrace files"
Sleep 300ms
Enter
Sleep 4s

Sleep 500ms
Type "agentrace water"
Sleep 300ms
Enter
Sleep 4s

Sleep 500ms
Type "agentrace recommend"
Sleep 300ms
Enter
Sleep 4s

Sleep 2s
